{
    "services": {
        "backend": {
            "root": "backend",
            "entrypoint": "server.js",
            "buildCommand": "cd ../frontend && npm install && npm run build"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        }
    ]
}
